PORT=8787
DATA_DIR=./src/data

# 强规则阈值
STRONG_RULE_THRESHOLD=4

# 最终执行拉黑阈值
AUTO_BLOCK_CONFIDENCE=0.8

# classify 接口每分钟每IP上限
CLASSIFY_RATE_PER_MINUTE=240

# 可选：插件调用后端时带 x-client-token
# CLIENT_TOKEN=your_client_token

# 可选：管理后台与管理接口鉴权
# ADMIN_TOKEN=your_admin_token

# 可选：接入外部便宜分类服务
# CHEAP_AI_URL=http://127.0.0.1:9001/classify

# 可选：OpenAI 兼容接口
# OPENAI_API_KEY=your_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHEAP_AI_MODEL=gpt-4o-mini
# AI_PROVIDER=auto
